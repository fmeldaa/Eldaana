# ─────────────────────────────────────────────────────────────────────────────
# Eldaana — Fichier de secrets (EXEMPLE)
# Copiez ce fichier en "secrets.toml" et remplissez vos vraies valeurs.
# NE JAMAIS mettre secrets.toml sur GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# Clé API Anthropic (Claude)
# Trouvez-la sur : https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY = "sk-ant-VOTRE_CLE_ICI"

[google]
# Google Cloud Console → APIs & Services → Identifiants → OAuth 2.0
# redirect_uri = URL de votre app (localhost en dev, URL Streamlit en prod)
client_id     = "VOTRE_CLIENT_ID.apps.googleusercontent.com"
client_secret = "VOTRE_CLIENT_SECRET"
redirect_uri  = "http://localhost:8503"

[supabase]
# supabase.com → votre projet → Settings → API
url = "https://VOTRE_PROJET.supabase.co"
key = "VOTRE_CLE_ANON"
