<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4A99A">

    <!-- Logo plein écran — PNG avec fond transparent -->
    <ImageView
        android:id="@+id/splashLogo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:src="@drawable/logo"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:padding="60dp"
        android:background="@android:color/transparent" />

    <!-- Fondu HAUT : beige opaque → transparent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/fade_top" />

    <!-- Fondu BAS : transparent → beige opaque -->
    <View
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:background="@drawable/fade_bottom" />

    <!-- Fondu GAUCHE -->
    <View
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical|start"
        android:background="@drawable/fade_left" />

    <!-- Fondu DROITE -->
    <View
        android:layout_width="100dp"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical|end"
        android:background="@drawable/fade_right" />

</FrameLayout>
